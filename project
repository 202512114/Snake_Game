#include <iostream>
#include <chrono>
#include <thread>
#include <termios.h>
#include <unistd.h>
#include <cstdlib>
#include <sys/select.h>
using namespace std;

const int r=20;
const int c=50;
int cs=0;
int hs=0;
int m1=1, m2=1;   // snake head position
int dx=0, dy=1;   // default direction (right)
char dch='>',df='+';
int fi, fj;       // food
char arr[r][c];

char getchNonBlocking() {
    char ch=0;
    termios oldt, newt;
    tcgetattr(STDIN_FILENO, &oldt);
    newt = oldt;
    newt.c_lflag &= ~(ICANON | ECHO);
    tcsetattr(STDIN_FILENO, TCSANOW, &newt);
    fd_set set;
    struct timeval tv{0,0};
    FD_ZERO(&set);
    FD_SET(STDIN_FILENO,&set);
    if(select(STDIN_FILENO+1,&set,NULL,NULL,&tv)>0) {
        read(STDIN_FILENO,&ch,1);
    }
    tcsetattr(STDIN_FILENO, TCSANOW, &oldt);
    return ch;
}

struct node {
    int mi,mj;
    char data;
    node *next;
};
node *head=NULL;

void insert(char data)
{
    struct node *n=new node;
    n->data=data;
    n->next=NULL;
    if(head==NULL)
    {
        head=n;
    }
    else
    {
        struct node *tn=head;
        while(tn->next!=NULL)
        {
            tn=tn->next;
        }
        tn->next=n;
    }
}

void display()
{
    string tempstr="";
    if(c>35)
    {
        for(int i=0;i<(c-31);i++)
        {
            tempstr+=" ";
        }
    }
    else
    {
        tempstr+="\n";
    }

    cout<<"Current Score:"<<cs<<tempstr<<"High Score:"<<hs<<endl;
    for(int i=0;i<r;i++) {
        for(int j=0;j<c;j++) {
            cout<<arr[i][j];
        }
        cout<<endl;
    }
}

void resetGame() {
    cs = 0;
    m1 = 1; m2 = 1; dx = 0; dy = 1; dch = '>';
    head = NULL;
    // reinitialize snake
    head = new node{m1,m2,dch,NULL};
    insert('+'); insert('+');
    fi=(rand()%(r-2))+1;
    fj=(rand()%(c-2))+1;
}

bool onSnake(int x, int y)
{
    if (x == m1 && y == m2)
        return true;
    node *tn = head;
    while (tn)
    {
        if (tn->mi == x && tn->mj == y)
            return true;
        tn = tn->next;
    }
    return false;
}

bool hitSnake(int x, int y)
{
    node *tn = head;
    tn=tn->next;
    while (tn)
    {
        if (tn->mi == x && tn->mj == y)
            return true;
        tn = tn->next;
    }
    return false;
}

void createGrid() {
    cout << "\033[H\033[J";
    for(int i=0;i<r;i++) {
        for(int j=0;j<c;j++) {
            if((i==0||i==r-1)||(j==0||j==c-1))
                arr[i][j]='#';
            else if(i==fi&&j==fj)
            {
                if(m1==fi&&m2==fj)
                {
                    insert(df);
                    cs+=10;
                    do
                    {
                        fi=(rand()%(r-2))+1;
                        fj=(rand()%(c-2))+1;
                    }while(onSnake(fi,fj));
                }
                else
                {
                    arr[i][j]='o';
                }
            }
            else
                arr[i][j]=' ';
            struct node *tn=head;
            while(tn!=NULL)
            {
                arr[tn->mi][tn->mj]=tn->data;
                tn=tn->next;
            }
        }
    }
    // arr[m1][m2] = '>'; // head on grid
    if((m1==0||m1==r-1)||(m2==0||m2==c-1))
    {
        m1-=dx;
        m2-=dy;
        arr[m1][m2] = dch;
        if(cs>hs)
        {
            hs=cs;
        }
        display();
        cout<<"Game Over!\nFinal Score: "<<cs<<"\n"<<endl;
        cout<<"Press any key-Restart\nX-Exit\n";
        char c = 0;
        while (c == 0)
        {
            c = getchNonBlocking();
        }

        switch(c)
        {
            case 'x':
            case 'X':exit(0);
            default:resetGame();
        }
    }
    else if(hitSnake(m1,m2))
    {
        m1-=dx;
        m2-=dy;
        arr[m1][m2] = dch;
        if(cs>hs)
        {
            hs=cs;
        }
        display();
        cout<<"Game Over!\nFinal Score: "<<cs<<"\n"<<endl;
        cout<<"Press any key-Restart\nX-Exit\n";
        char c = 0;
        while (c == 0)
        {
            c = getchNonBlocking();
        }

        switch(c)
        {
            case 'x':
            case 'X':exit(0);
            default:resetGame();
        }
    }
    else
    {
        arr[m1][m2] = dch;
    }
}

void changeIndex() {
    if (!head) return;
    node *tn = head;
    int prev_i = m1, prev_j = m2; // head will take new position
    while (tn)
    {
        int temp_i = tn->mi;
        int temp_j = tn->mj;
        tn->mi = prev_i;
        tn->mj = prev_j;
        prev_i = temp_i;
        prev_j = temp_j;
        tn = tn->next;
    }
}

void handleInput() {
    char ch = getchNonBlocking();
    if(ch=='\033')
    {
        getchNonBlocking(); // skip '['
        switch(getchNonBlocking()) {
            case 'A': dx=-1; dy=0; dch='^'; break; // up
            case 'B': dx=1;  dy=0; dch='v'; break; // down
            case 'C': dx=0;  dy=1; dch='>'; break; // right
            case 'D': dx=0;  dy=-1; dch='<'; break; // left
        }
    }
    else
    {
        switch(ch)
        {
            case 'w':
            case 'W': dx=-1; dy=0; dch='^'; break; // up
            case 'a':
            case 'A': dx=0;  dy=-1; dch='<'; break; // left
            case 's':
            case 'S': dx=1;  dy=0; dch='v'; break; // down
            case 'd':
            case 'D': dx=0;  dy=1; dch='>'; break; // right
        }
    }
}

int main()
{
    head = new node;
    head->mi = m1;
    head->mj = m2;
    head->data = dch;
    head->next = NULL;

    node* b1 = new node{m1, m2-1, '+', NULL};
    node* b2 = new node{m1, m2-2, '+', NULL};
    head->next = b1;
    b1->next = b2;

    srand(time(0));
    fi=(rand()%(r-2))+1;
    fj=(rand()%(c-2))+1;

    while(true) {
        handleInput();         // check arrow keys
        m1 += dx;              // update position each tick
        m2 += dy;

        changeIndex();
        createGrid();          // draw grid and snake
        display();

        this_thread::sleep_for(chrono::milliseconds(200));
    }
    return 0;
}
